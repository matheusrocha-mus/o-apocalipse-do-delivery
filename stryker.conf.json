{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.js",
    "!src/server.js"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 90
  },
  "timeoutMS": 20000
}
